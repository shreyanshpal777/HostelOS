NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

MONGODB_URI=mongodb://127.0.0.1:27017/hostel_ai
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

GEMINI_API_KEY=replace_with_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

WHATSAPP_PROVIDER=meta
WHATSAPP_CLOUD_API_VERSION=v20.0
WHATSAPP_PHONE_NUMBER_ID=replace_with_meta_phone_number_id
WHATSAPP_ACCESS_TOKEN=replace_with_meta_access_token
WHATSAPP_VERIFY_TOKEN=replace_with_webhook_verify_token
WHATSAPP_BUSINESS_ACCOUNT_ID=replace_with_business_account_id

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

UPLOAD_DIR=uploads
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
